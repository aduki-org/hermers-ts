{
  "name": "@hermers/sdk",
  "version": "1.1.0",
  "description": "Hermes HTTP SDK REST client library for Node.js & TypeScript",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "hermes",
    "sdk",
    "http",
    "rest",
    "api",
    "email",
    "mail",
    "contacts",
    "calendar",
    "events",
    "scheduling",
    "tenant",
    "auth"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
