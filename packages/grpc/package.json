{
  "name": "@hermers/grpc",
  "version": "1.1.0",
  "description": "Hermes gRPC-Web client library for Node.js & TypeScript",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "hermes",
    "grpc",
    "grpc-web",
    "proto3",
    "email",
    "mail",
    "contacts",
    "storage",
    "spam",
    "tier",
    "usage",
    "sync",
    "session"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
